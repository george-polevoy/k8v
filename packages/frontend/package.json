{
  "name": "@k8v/frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "snapshot:canvas": "node scripts/captureCanvasSnapshot.mjs",
    "test:e2e": "sh -c 'find tests/e2e -name \"*.test.ts\" | LC_ALL=C sort | while IFS= read -r file; do tsx --test \"$file\" || exit $?; done'"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "katex": "^0.16.11",
    "pixi.js": "^7.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.10.4",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "playwright": "^1.58.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
